datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  name       String
  avatar_url String?
  timezone   String   @default("UTC")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}